; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but it can also be edited manually with some care.

[application]

config/name="Voxel Extraction"
config/description="Voxel PvE extraction game — co-op, destructible terrain, AI-generated assets."
config/tags=PackedStringArray("3d", "voxel", "extraction", "pve", "coop")
run/main_scene="res://scenes/world/main.tscn"
config/features=PackedStringArray("4.6", "Vulkan")
config/icon="res://assets/ui/icon.svg"

[autoload]

AntiCheat="*res://scripts/anticheat/anticheat_autoload.gd"
GameManager="*res://scripts/systems/game_manager.gd"
ExtractionManager="*res://scripts/systems/extraction_manager.gd"
LootTable="*res://scripts/systems/loot_table.gd"
AudioManager="*res://scripts/systems/audio_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/mode=2
window/vsync/vsync_mode=1

